{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_SITE_NAME",
    "NEXT_PUBLIC_CONTACT_EMAIL",
    "NEXT_PUBLIC_GITHUB_URL",
    "NEXT_PUBLIC_ADSENSE_CLIENT_ID",
    "NEXT_PUBLIC_ANALYTICS_ID"
  ],
  "tasks": {
    "dev": { "cache": false, "persistent": true },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": { "dependsOn": ["^lint"] },
    "typecheck": { "dependsOn": ["^typecheck"] },
    "test": { "dependsOn": ["^build"], "cache": false },
    "test:coverage": { "dependsOn": ["^build"], "cache": false },
    "@viettools/developer-utils#build": { "cache": false },
    "@viettools/text-utils#build": { "cache": false },
    "@viettools/ui#build": { "cache": false },
    "@viettools/vietnamese-utils#build": { "cache": false }
  }
}
